<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:background="@drawable/game_item_background"
    android:backgroundTint="#11FFFFFF"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/score_rank"
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:text="@string/placeholder_name"
        android:textColor="#FFD700"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/score_medal"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="8dp"
        android:scaleType="fitCenter" />

    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp">
        <View
            android:id="@+id/score_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/avatar_circle_placeholder" />
        <ImageView
            android:id="@+id/score_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:scaleType="fitCenter" />
    </FrameLayout>

    <TextView
        android:id="@+id/score_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/placeholder_name"
        android:textColor="#FFFFFF"
        android:textSize="20sp" />

    <ImageView
        android:id="@+id/score_trophy"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_trophy"
        android:visibility="gone" />

    <TextView
        android:id="@+id/score_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/placeholder_score"
        android:textColor="#00E5FF"
        android:textSize="24sp"
        android:textStyle="bold" />

</LinearLayout>
