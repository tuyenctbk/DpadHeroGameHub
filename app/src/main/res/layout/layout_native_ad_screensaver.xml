<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/screensaver_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2000000">

    <com.google.android.gms.ads.nativead.NativeAdView
        android:id="@+id/native_ad_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:id="@+id/drift_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="48dp">

            <!-- Top Message -->
            <TextView
                android:id="@+id/support_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:text="To keep these games free, we show ads during breaks.\nThank you for your support!"
                android:textAlignment="center"
                android:textColor="#B0BEC5"
                android:textSize="18sp"
                android:lineSpacingExtra="4dp" />

            <!-- Large Media Content -->
            <com.google.android.gms.ads.nativead.MediaView
                android:id="@+id/ad_media"
                android:layout_width="640dp"
                android:layout_height="360dp"
                android:layout_centerInParent="true"
                android:background="#1A1A1A" />

            <!-- Ad Attribution -->
            <TextView
                android:id="@+id/ad_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignStart="@id/ad_media"
                android:layout_above="@id/ad_media"
                android:layout_marginBottom="8dp"
                android:background="#FFCA28"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="ADVERTISEMENT"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Info Section -->
            <LinearLayout
                android:layout_width="640dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/ad_media"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ad_app_icon"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:scaleType="fitCenter" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/ad_headline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:ellipsize="end"
                        android:maxLines="1" />

                    <TextView
                        android:id="@+id/ad_body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#B0BEC5"
                        android:textSize="16sp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/ad_call_to_action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/game_item_background"
                    android:backgroundTint="#4CAF50"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Bottom Wake Hint -->
            <TextView
                android:id="@+id/wake_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:text="Press any key to resume instantly"
                android:textColor="#66FFFFFF"
                android:textSize="14sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

        </RelativeLayout>
    </com.google.android.gms.ads.nativead.NativeAdView>

    <!-- 3s Warning Overlay (Only visible during warning state) -->
    <LinearLayout
        android:id="@+id/warning_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="100dp"
        android:background="@drawable/game_item_background"
        android:backgroundTint="#CC000000"
        android:orientation="horizontal"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/warning_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full-screen ad starting in 3..."
            android:textColor="#FFCA28"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>
