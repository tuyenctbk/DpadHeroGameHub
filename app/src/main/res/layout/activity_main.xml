<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="32dp">

    <ImageButton
        android:id="@+id/btn_settings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/settings_button_description"
        android:focusable="true"
        android:nextFocusDown="@id/btn_snake"
        android:scaleType="centerInside"
        android:src="@android:drawable/ic_menu_preferences"
        android:tint="#FFFFFF" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/game_center"
            android:textColor="#FFFFFF"
            android:textSize="48sp"
            android:textStyle="bold"
            android:layout_marginBottom="48dp" />

        <HorizontalScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_snake"
                android:layout_width="200dp"
                android:layout_height="240dp"
                android:backgroundTint="@color/btn_snake_color"
                android:elevation="8dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:nextFocusUp="@id/btn_settings"
                android:text="@string/snake"
                android:drawableTop="@drawable/ic_game_snake"
                android:paddingTop="32dp"
                android:drawablePadding="16dp"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_minesweeper"
                android:layout_width="200dp"
                android:layout_height="240dp"
                android:layout_marginStart="32dp"
                android:backgroundTint="@color/btn_minesweeper_color"
                android:elevation="8dp"
                android:focusable="true"
                android:nextFocusUp="@id/btn_settings"
                android:text="@string/minesweeper"
                android:drawableTop="@drawable/ic_game_minesweeper"
                android:paddingTop="32dp"
                android:drawablePadding="16dp"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_4096"
                android:layout_width="200dp"
                android:layout_height="240dp"
                android:layout_marginStart="32dp"
                android:backgroundTint="@color/btn_4096_color"
                android:elevation="8dp"
                android:focusable="true"
                android:nextFocusUp="@id/btn_settings"
                android:text="@string/game_4096"
                android:drawableTop="@drawable/ic_game_4096"
                android:paddingTop="32dp"
                android:drawablePadding="16dp"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_trex"
                android:layout_width="200dp"
                android:layout_height="240dp"
                android:layout_marginStart="32dp"
                android:backgroundTint="@color/btn_trex_color"
                android:elevation="8dp"
                android:focusable="true"
                android:nextFocusUp="@id/btn_settings"
                android:text="@string/game_trex"
                android:drawableTop="@drawable/ic_game_trex"
                android:paddingTop="32dp"
                android:drawablePadding="16dp"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_brick_break"
                android:layout_width="200dp"
                android:layout_height="240dp"
                android:layout_marginStart="32dp"
                android:backgroundTint="@color/btn_brick_break_color"
                android:elevation="8dp"
                android:focusable="true"
                android:nextFocusUp="@id/btn_settings"
                android:text="@string/game_brick_break"
                android:drawableTop="@drawable/ic_game_brick_break"
                android:paddingTop="32dp"
                android:drawablePadding="16dp"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_tictactoe"
                android:layout_width="200dp"
                android:layout_height="240dp"
                android:layout_marginStart="32dp"
                android:backgroundTint="@color/btn_tictactoe_color"
                android:elevation="8dp"
                android:focusable="true"
                android:nextFocusUp="@id/btn_settings"
                android:text="@string/game_tictactoe"
                android:drawableTop="@drawable/ic_game_tictactoe"
                android:paddingTop="32dp"
                android:drawablePadding="16dp"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_checkers"
                android:layout_width="200dp"
                android:layout_height="240dp"
                android:layout_marginStart="32dp"
                android:backgroundTint="@color/btn_checkers_color"
                android:elevation="8dp"
                android:focusable="true"
                android:nextFocusUp="@id/btn_settings"
                android:text="@string/game_checkers"
                android:drawableTop="@drawable/ic_game_checkers"
                android:paddingTop="32dp"
                android:drawablePadding="16dp"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_sokoban"
                android:layout_width="200dp"
                android:layout_height="240dp"
                android:layout_marginStart="32dp"
                android:backgroundTint="@color/btn_sokoban_color"
                android:elevation="8dp"
                android:focusable="true"
                android:nextFocusUp="@id/btn_settings"
                android:text="@string/game_sokoban"
                android:drawableTop="@drawable/ic_game_sokoban"
                android:paddingTop="32dp"
                android:drawablePadding="16dp"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_sudoku"
                android:layout_width="200dp"
                android:layout_height="240dp"
                android:layout_marginStart="32dp"
                android:backgroundTint="@color/btn_sudoku_color"
                android:elevation="8dp"
                android:focusable="true"
                android:nextFocusUp="@id/btn_settings"
                android:text="@string/game_sudoku"
                android:drawableTop="@drawable/ic_game_sudoku"
                android:paddingTop="32dp"
                android:drawablePadding="16dp"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="@string/select_game_hint"
        android:textColor="#AAAAAA"
        android:textSize="18sp" />

    </LinearLayout>
</RelativeLayout>
