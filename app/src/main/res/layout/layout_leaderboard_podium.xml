<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="bottom|center_horizontal"
    android:orientation="horizontal"
    android:padding="24dp"
    android:clipChildren="false">

    <!-- 2nd Place -->
    <LinearLayout
        android:id="@+id/podium_2"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="invisible">

        <FrameLayout
            android:layout_width="70dp"
            android:layout_height="70dp">
            <View
                android:id="@+id/avatar_2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/avatar_circle_placeholder" />
            <ImageView
                android:id="@+id/icon_2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <TextView
            android:id="@+id/name_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_name"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/score_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_score"
            android:textColor="#00E5FF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="100dp"
            android:layout_height="80dp"
            android:background="#A0A0A0" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/rank_2nd"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginTop="-50dp" />
    </LinearLayout>

    <!-- 1st Place -->
    <LinearLayout
        android:id="@+id/podium_1"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:visibility="invisible">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_trophy"
            android:layout_marginBottom="4dp" />

        <FrameLayout
            android:layout_width="90dp"
            android:layout_height="90dp">
            <View
                android:id="@+id/avatar_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/avatar_circle_placeholder" />
            <ImageView
                android:id="@+id/icon_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="18dp"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <TextView
            android:id="@+id/name_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_name"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/score_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_score"
            android:textColor="#00E5FF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="#FFD700" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/rank_1st"
            android:textColor="#000000"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="-80dp" />
    </LinearLayout>

    <!-- 3rd Place -->
    <LinearLayout
        android:id="@+id/podium_3"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="invisible">

        <FrameLayout
            android:layout_width="70dp"
            android:layout_height="70dp">
            <View
                android:id="@+id/avatar_3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/avatar_circle_placeholder" />
            <ImageView
                android:id="@+id/icon_3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <TextView
            android:id="@+id/name_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_name"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/score_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_score"
            android:textColor="#00E5FF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:background="#CD7F32" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/rank_3rd"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginTop="-35dp" />
    </LinearLayout>

</LinearLayout>
