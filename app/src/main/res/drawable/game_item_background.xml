<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state with a bright border and subtle scaling effect (handled via elevation/scale in code or just visual border here) -->
    <item android:state_focused="true">
        <inset
            android:insetLeft="4dp"
            android:insetTop="4dp"
            android:insetRight="4dp"
            android:insetBottom="4dp">
            <shape android:shape="rectangle">
                <solid android:color="@android:color/transparent" /> <!-- Background color will be set via backgroundTint -->
                <corners android:radius="12dp" />
                <stroke
                    android:width="4dp"
                    android:color="#FFFFFF" />
            </shape>
        </inset>
    </item>
    <!-- Default state -->
    <item>
        <inset
            android:insetLeft="4dp"
            android:insetTop="4dp"
            android:insetRight="4dp"
            android:insetBottom="4dp">
            <shape android:shape="rectangle">
                <solid android:color="@android:color/transparent" /> <!-- Background color will be set via backgroundTint -->
                <corners android:radius="12dp" />
                <stroke
                    android:width="1dp"
                    android:color="#33FFFFFF" />
            </shape>
        </inset>
    </item>
</selector>
