<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <!-- Deep Space Background -->
    <path
        android:pathData="M0,0h320v180h-320z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endY="180"
                android:startY="0"
                android:type="linear">
                <item android:color="#05050A" android:offset="0" />
                <item android:color="#121225" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Neon Horizon Glow -->
    <path
        android:pathData="M0,90h320v90h-320z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="160"
                android:centerY="180"
                android:gradientRadius="180"
                android:type="radial">
                <item android:color="#44FF00CC" android:offset="0" />
                <item android:color="#00FF00CC" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Cyber Grid (Perspective) -->
    <path
        android:strokeColor="#2200F2FF"
        android:strokeWidth="1"
        android:pathData="M0,110 L320,110 M0,130 L320,130 M0,155 L320,155 M0,180 L320,180" />
    <path
        android:strokeColor="#2200F2FF"
        android:strokeWidth="1"
        android:pathData="M160,100 L0,180 M160,100 L80,180 M160,100 L160,180 M160,100 L240,180 M160,100 L320,180" />

    <!-- Neon Arcade Arc -->
    <path
        android:strokeColor="#3300F2FF"
        android:strokeWidth="2"
        android:pathData="M40,180 Q160,100 280,180" />

    <!-- Central Logo Glow -->
    <path
        android:pathData="M160,85m-65,0a65,65 0 1,1 130,0a65,65 0 1,1 -130,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="160"
                android:centerY="85"
                android:gradientRadius="65"
                android:type="radial">
                <item android:color="#5500F2FF" android:offset="0" />
                <item android:color="#0000F2FF" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Hexagonal D-Pad Shield -->
    <path
        android:pathData="M160,50 L195,65 L195,105 L160,120 L125,105 L125,65 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endY="120"
                android:startY="50"
                android:type="linear">
                <item android:color="#2D2D44" android:offset="0" />
                <item android:color="#161625" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>
    <path
        android:strokeColor="#00F2FF"
        android:strokeWidth="2"
        android:pathData="M160,50 L195,65 L195,105 L160,120 L125,105 L125,65 Z" />

    <!-- The "Hero" D-Pad -->
    <!-- D-Pad Base -->
    <path
        android:fillColor="#111111"
        android:pathData="M145,80 h30 v10 h-30 z M155,70 v30 h10 v-30 z" />

    <!-- D-Pad Directional Neon Accents -->
    <path
        android:fillColor="#00F2FF"
        android:pathData="M155,70 h10 v5 h-10 z" /> <!-- Up -->
    <path
        android:fillColor="#00F2FF"
        android:pathData="M155,95 h10 v5 h-10 z" /> <!-- Down -->
    <path
        android:fillColor="#00F2FF"
        android:pathData="M145,80 h5 v10 h-5 z" /> <!-- Left -->
    <path
        android:fillColor="#00F2FF"
        android:pathData="M170,80 h5 v10 h-5 z" /> <!-- Right -->

    <!-- Center OK/Action Button -->
    <path
        android:fillColor="#FF00CC"
        android:pathData="M160,85 m-6,0 a6,6 0 1,1 12,0 a6,6 0 1,1 -12,0" />

    <!-- Top Gloss Shine on Shield -->
    <path
        android:pathData="M160,50 L195,65 v10 h-70 v-10 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endY="75"
                android:startY="50"
                android:type="linear">
                <item android:color="#22FFFFFF" android:offset="0" />
                <item android:color="#00FFFFFF" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Optimized Scanline Overlay -->
    <path
        android:fillColor="#08FFFFFF"
        android:pathData="M0,4h320v1h-320z M0,12h320v1h-320z M0,20h320v1h-320z M0,28h320v1h-320z M0,36h320v1h-320z M0,44h320v1h-320z M0,52h320v1h-320z M0,60h320v1h-320z M0,68h320v1h-320z M0,76h320v1h-320z M0,84h320v1h-320z M0,92h320v1h-320z M0,100h320v1h-320z M0,108h320v1h-320z M0,116h320v1h-320z M0,124h320v1h-320z M0,132h320v1h-320z M0,140h320v1h-320z M0,148h320v1h-320z M0,156h320v1h-320z M0,164h320v1h-320z M0,172h320v1h-320z" />

</vector>
